<h1>
    <%= title %>
</h1>

<% if (message) { %>
    <p class="notice">
        <%= message %>
    </p>
    <% } %>

<% if (errors) { %>
    <ul class="errors">
        <% errors.forEach(error=> { %>
            <li>
                <%= error.msg %>
            </li>
            <% }) %>
    </ul>
    <% } %>

        <form action="/inv/add-classification" method="post">
            <label for="classification_name">Classification Name</label>

            <input type="text" id="classification_name" name="classification_name" required pattern="[A-Za-z]+"
                title="Only letters allowed (no numbers or spaces)" value="<%= classification_name || '' %>">

            <button type="submit">Add Classification</button>
        </form>
        <a href="/inv">← Back to Management</a>