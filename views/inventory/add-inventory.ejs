<div class="form-container">
    <h1>
        <%= title %>
    </h1>
    <% if (errors) { %>
        <ul class="errors">
            <% errors.forEach(error=> { %> <li>
                    <%= error.msg %>
                </li>
                <% }) %>
        </ul>
        <% } %>
            <p class="form-note">ALL FIELDS ARE REQUIRED.</p>
            <form action="/inv/add-inventory" method="post" class="styled-form" novalidate>
                <label>Classification</label> <%- classificationList %> <label>Make</label> <input type="text"
                        name="inv_make" minlength="3" required class="validate" value="<%= inv_make || '' %>"
                        placeholder="Min of 3 characters"> <label>Model</label> <input type="text" name="inv_model"
                        minlength="3" required class="validate" value="<%= inv_model || '' %>"
                        placeholder="Min of 3 characters"> <label>Year (4 digits)</label> <input type="number"
                        name="inv_year" min="1000" max="9999" required value="<%= inv_year || '' %>"
                        placeholder="4-digit year"> <label>Description</label> <textarea name="inv_description"
                        minlength="3" required class="validate"
                        placeholder="Min of 3 characters"><%= inv_description || '' %></textarea> <label>Image
                        Path</label> <input type="text" name="inv_image" required value="<%= inv_image || '' %>">
                    <label>Thumbnail Path</label> <input type="text" name="inv_thumbnail" required
                        value="<%= inv_thumbnail || '' %>"> <label>Price</label> <input type="number" name="inv_price"
                        step="0.01" required value="<%= inv_price || '' %>" placeholder="decimal or integer">
                    <label>Miles (numbers only)</label> <input type="number" name="inv_miles" required
                        value="<%= inv_miles || '' %>" placeholder="digits only"> <label>Color</label> <input
                        type="text" name="inv_color" minlength="3" required class="validate"
                        value="<%= inv_color || '' %>" placeholder="Min of 3 characters"> <button type="submit">Add
                        Inventory</button> </form> <a href="/inv" class="back-link">← Back to Management</a>
</div>