<div class="form-container">
    <h1>
        <%= title %>
    </h1>

    <% if (errors) { %>
        <ul class="errors">
            <% errors.forEach(error=> { %>
                <li>
                    <%= error.msg %>
                </li>
                <% }) %>
        </ul>
        <% } %>

            <p class="form-note">ALL FIELDS ARE REQUIRED.</p>

            <form action="/account/register" method="post" class="styled-form" novalidate>

                <!-- First Name -->
                <label for="account_firstname">First Name</label>
                <input type="text" name="account_firstname" id="account_firstname" required
                    value="<%= account_firstname || '' %>" placeholder="Enter your first name">

                <!-- Last Name -->
                <label for="account_lastname">Last Name</label>
                <input type="text" name="account_lastname" id="account_lastname" required
                    value="<%= account_lastname || '' %>" placeholder="Enter your last name">

                <!-- Email -->
                <label for="account_email">Email</label>
                <input type="email" name="account_email" id="account_email" required value="<%= account_email || '' %>"
                    placeholder="Enter a valid email">

                <!-- Password -->
                <label for="account_password">Password</label>
                <input type="password" name="account_password" id="account_password" required minlength="12"
                    placeholder="At least 12 characters, include uppercase, lowercase, number, and symbol">

                <!-- Submit -->
                <button type="submit">Register Account</button>

            </form>

            <a href="/account/login" class="back-link">Already have an account? Login</a>
</div>