<header id="top-header">
    <span class="siteName">
        <a href="/" title="Return to home page">CSE Motors</a>
    </span>

    <div id="tools" aria-label="Account management">
        <% if (accountData) { %>
            <a href="/account/">
                Welcome <%= accountData.account_firstname %> (<%= accountData.account_type %>)
            </a>
            <a href="/account/logout">Logout</a>
            <% } else { %>
                <a href="/account/login">My Account</a>
                <% } %>
    </div>
</header>